// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// User Roles
enum UserRole {
  STUDENT
  FACULTY
  STAFF
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// Request Types
enum RequestType {
  GMC  // Good Moral Certificate
  UER  // Uniform Exemption Request
  CDC  // Cross-Dressing Clearance
  CAC  // Child Admission Clearance
}

enum RequestStatus {
  NEW
  PROCESSING
  ISSUED
  HOLD
  REJECTED
}

// Offense Categories
enum OffenseCategory {
  MINOR
  MAJOR
  LATE_FACULTY_EVALUATION
  LATE_ACCESS_ROG
  LATE_PAYMENT
  OTHER
}

// Offense Severity Levels
enum OffenseLevel {
  FIRST
  SECOND
  THIRD
  FOURTH
  FIFTH
}

// Complaint Categories
enum ComplaintCategory {
  MAJOR
  MINOR
  OTHER
}

enum ComplaintStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
  REOPENED
}

enum TemplateType {
  CERTIFICATE
  EMAIL
}

// Endorsement Types
enum EndorsementType {
  ADMINISTRATIVE_SERVICE
  COMMUNITY_SERVICE
}

enum EndorsementStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// USER MODELS
// ============================================

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  password      String
  name          String?
  role          UserRole      @default(STAFF)
  status        UserStatus    @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  lastLoginAt   DateTime?
  
  // Relations
  requests      Request[]
  complaints    Complaint[]
  announcements Announcement[]
  auditLogs     AuditLog[]
  templates     Template[]
  notifications Notification[]
  processedOffenses DisciplinaryOffense[] @relation("ProcessedBy")
  clearedOffenses   OffenseClearance[]    @relation("ClearedBy")
  endorsements      Endorsement[]         @relation("ProcessedEndorsements")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  message     String
  type        String
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  fullName        String?
  givenName       String?
  surname         String?
  middleName      String?
  extensionName   String?
  email           String   @unique
  studentNumber   String?
  collegeInstitute String?
  yearLevel       String?
  sex             String?
  course          String?
  phone           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// REQUEST MODELS
// ============================================

model Request {
  id                    String        @id @default(cuid())
  controlNumber         String        @unique
  requestType           RequestType
  status                RequestStatus @default(NEW)
  
  // Requestor info (anonymous, no account required)
  requestorFirstName    String
  requestorMiddleName   String?
  requestorLastName     String
  requestorExtensionName String?
  requestorEmail        String
  requestorPhone        String?
  requestorStudentNo    String
  requestorCollege      String
  requestorCourse       String?
  requestorYearLevel    String?
  requestorSex          String?
  
  // Classification (for GMC)
  classification        String?
  yearGraduated         String?
  
  // Purpose
  purpose               String
  otherPurpose          String?
  
  // Type-specific fields (JSON)
  additionalData        String?
  
  // Documents (JSON array)
  documents             String?
  
  // Processing
  remarks               String?
  processedBy           String?
  processedAt           DateTime?
  processorName         String?  // Name of staff who processed
  
  // Certificate
  certificateUrl        String?
  certificateIssuedAt   DateTime?
  certificateExpiresAt  DateTime?
  
  // Tracking
  trackingToken         String        @unique
  qrCode                String?       @unique
  
  // Email sent tracking
  emailSentAt           DateTime?
  
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  
  processor             User?         @relation(fields: [processedBy], references: [id])
  
  // Relations for specific request types
  childInfos            ChildInfo[]
  uniformExemptionData  UniformExemptionData?
  
  @@index([requestType])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// CHILD ADMISSION CLEARANCE - CHILD INFO
// ============================================

model ChildInfo {
  id                String   @id @default(cuid())
  requestId         String
  
  // Child Information
  surname           String
  givenName         String
  middleName        String?
  extensionName     String?
  sex               String
  age               Int
  
  // Child Photo
  photoUrl          String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  request           Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  
  @@index([requestId])
}

// ============================================
// UNIFORM EXEMPTION - CATEGORY DATA
// ============================================

model UniformExemptionData {
  id                    String   @id @default(cuid())
  requestId             String   @unique
  
  // Category
  category              String  // working_student, office_org_event, ojt, college_org_shirt, other
  
  // Category-specific answers (JSON)
  categoryAnswers       String?
  
  // Documents (JSON array)
  documents             String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  request               Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  
  @@index([requestId])
}

// ============================================
// COMPLAINT MODEL
// ============================================

model Complaint {
  id              String          @id @default(cuid())
  controlNumber   String          @unique
  complainants    String          // JSON array
  respondents     String          // JSON array
  category        ComplaintCategory?
  complaintType   String?
  specifyOther    String?         // For "Other" category
  status          ComplaintStatus @default(PENDING)
  
  subject         String
  description     String
  dateOfIncident  String?
  location        String?
  isOngoing       Boolean         @default(false)
  howOften        String?
  witnesses       String?         // JSON array
  previousReports String?
  
  // Supporting Evidence Documents (JSON array)
  documents       String?
  
  // Processing
  remarks         String?
  processedBy     String?
  processedAt     DateTime?
  
  // Tracking
  trackingToken   String          @unique
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  processor       User?           @relation(fields: [processedBy], references: [id])
  
  @@index([status])
  @@index([createdAt])
}

// ============================================
// DISCIPLINARY RECORDS
// ============================================

model DisciplinaryRecord {
  id                String   @id @default(cuid())
  studentNumber     String
  studentName       String
  college           String?
  course            String?
  yearLevel         String?
  
  // Total counts by category
  minorCount        Int      @default(0)
  majorCount        Int      @default(0)
  lateFacultyCount  Int      @default(0)
  lateRogCount      Int      @default(0)
  latePaymentCount  Int      @default(0)
  otherCount        Int      @default(0)
  
  // Overall status
  hasActiveOffenses Boolean  @default(false)
  isEndorsed        Boolean  @default(false)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  offenses          DisciplinaryOffense[]
  clearances        OffenseClearance[]
  endorsements      Endorsement[]
  
  @@unique([studentNumber])
  @@index([studentNumber])
}

model DisciplinaryOffense {
  id                String           @id @default(cuid())
  recordId          String
  
  // Offense Details
  offenseCategory   OffenseCategory
  offenseLevel      OffenseLevel
  offenseDate       DateTime         @default(now())
  
  // For "Other" category
  specifyOther      String?
  
  // Description
  description       String?
  controlNumber     String?          // Related complaint/control number
  
  // Processing
  processedBy       String?
  processedAt       DateTime?
  
  // Status
  isCleared         Boolean          @default(false)
  clearedAt         DateTime?
  
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  record            DisciplinaryRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  processor         User?            @relation("ProcessedBy", fields: [processedBy], references: [id])
  
  @@index([recordId])
  @@index([offenseCategory])
  @@index([isCleared])
}

model OffenseClearance {
  id                String   @id @default(cuid())
  recordId          String
  
  // Clearance Details
  clearedBy         String
  clearedAt         DateTime @default(now())
  reason            String
  
  // Cleared offense counts (snapshot at time of clearance)
  minorCleared      Int      @default(0)
  majorCleared      Int      @default(0)
  lateFacultyCleared Int     @default(0)
  lateRogCleared    Int      @default(0)
  latePaymentCleared Int     @default(0)
  otherCleared      Int      @default(0)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  record            DisciplinaryRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  clearedByUser     User     @relation("ClearedBy", fields: [clearedBy], references: [id])
  
  @@index([recordId])
  @@index([clearedAt])
}

model Endorsement {
  id                String            @id @default(cuid())
  recordId          String
  
  // Endorsement Details
  type              EndorsementType
  status            EndorsementStatus @default(PENDING)
  
  // Trigger info
  triggeredByCategory OffenseCategory
  triggeredByLevel   OffenseLevel
  
  // Details
  details           String?
  hoursRequired     Int?
  hoursCompleted    Int?
  
  // Processing
  processedBy       String?
  processedAt       DateTime?
  completedAt       DateTime?
  remarks           String?
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  record            DisciplinaryRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  processor         User?             @relation("ProcessedEndorsements", fields: [processedBy], references: [id])
  
  @@index([recordId])
  @@index([status])
}

// ============================================
// CONTENT MANAGEMENT
// ============================================

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  isPinned    Boolean  @default(false)
  isActive    Boolean  @default(true)
  postedFrom  DateTime
  postedTo    DateTime?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  author      User     @relation(fields: [createdBy], references: [id])
  
  @@index([isActive])
  @@index([postedFrom])
}

model Template {
  id            String       @id @default(cuid())
  name          String
  templateType  TemplateType
  filename      String?
  storagePath   String?
  placeholders  String?
  subject       String?
  bodyHtml      String?
  isActive      Boolean      @default(true)
  createdBy     String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  author        User         @relation(fields: [createdBy], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  userName    String?
  action      String
  module      String
  recordId    String?
  oldValue    String?
  newValue    String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  user        User?    @relation(fields: [userId], references: [id])
  
  @@index([module])
  @@index([createdAt])
}

model CmsContent {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  value       String
  updatedBy   String?
  updatedAt   DateTime @updatedAt
}

model ManagedList {
  id          String   @id @default(cuid())
  listType    String
  label       String
  value       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  
  @@index([listType])
}

model OfficeHours {
  id          String   @id @default(cuid())
  dayOfWeek   Int
  openTime    String
  closeTime   String
  isOpen      Boolean  @default(true)
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

